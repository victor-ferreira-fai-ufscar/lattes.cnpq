# Lattes Scraper - Configurações de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ===========================================
# API KEYS (OBRIGATÓRIAS)
# ===========================================

# (Atualmente o scraping Playwright não exige chave de IA)

# ===========================================
# CONFIGURAÇÕES DO NAVEGADOR (OPCIONAIS)
# ===========================================

# Browser do Playwright: chromium, firefox ou webkit
PLAYWRIGHT_BROWSER=chromium

# Executar sem interface gráfica
PLAYWRIGHT_HEADLESS=true

# Porta do backend (padrão: 8000)
BACKEND_PORT=8000

# Porta do frontend (padrão: 3000)
FRONTEND_PORT=3000

# ===========================================
# CONFIGURAÇÕES AVANÇADAS (OPCIONAIS)
# ===========================================

# Timeout para requests da API (segundos)
API_TIMEOUT=30

# Diretório de saída para arquivos gerados
OUTPUT_DIR=output

# Dica:
# Rode "uv run playwright install chromium" após instalar dependências

# ===========================================
# SUPABASE STORAGE (OBRIGATÓRIO PARA /scrape)
# ===========================================

SUPABASE_URL=https://your-project-ref.supabase.co

# Use service role no backend (recomendado) — bypassa RLS e permite upload.
# Obtenha em: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Bucket e pasta onde os PDFs serão salvos
SUPABASE_STORAGE_BUCKET=lattes-cvs
SUPABASE_STORAGE_FOLDER=raw

# true: retorna URL pública (bucket público)
# false: retorna URL assinada com expiração
SUPABASE_STORAGE_PUBLIC=true
SUPABASE_SIGNED_URL_EXPIRES_IN=3600
