# Lattes Scraper - Configurações de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ===========================================
# NAVEGADOR PLAYWRIGHT
# ===========================================

# Browser: chromium, firefox ou webkit
PLAYWRIGHT_BROWSER=chromium

# Executar sem interface gráfica (false = visualiza o browser)
PLAYWRIGHT_HEADLESS=true

# Timeout para scraping (millisegundos)
PLAYWRIGHT_TIMEOUT_MS=45000

# Número de tentativas para retry em caso de falha
SCRAPE_RETRY_COUNT=3

# ===========================================
# SERVIDOR
# ===========================================

# Porta do backend
BACKEND_PORT=8000

# Porta do frontend
FRONTEND_PORT=3000

# ===========================================
# SAÍDA & ARMAZENAMENTO
# ===========================================

# Diretório local de saída (fallback se não usar Supabase)
OUTPUT_DIR=output

# Bucket e pasta no Supabase Storage
OUTPUT_BUCKET=lattes-cvs
OUTPUT_FOLDER_RAW=raw
OUTPUT_FOLDER_STRUCTURED=structured

# Máximo de processamentos simultâneos em lote
BATCH_MAX_CONCURRENT=5

# Timeout total para processamento em lote (segundos)
BATCH_TIMEOUT_TOTAL_SECONDS=3600

# ===========================================
# LOGGING & OBSERVABILIDADE
# ===========================================

# Nível de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# API_TIMEOUT para requests HTTP (segundos)
API_TIMEOUT=30

# Dica:
# Rode "uv run playwright install chromium" após instalar dependências

# ===========================================
# SUPABASE STORAGE (OBRIGATÓRIO PARA /scrape)
# ===========================================

SUPABASE_URL=https://your-project-ref.supabase.co

# Use service role no backend (recomendado) — bypassa RLS e permite upload.
# Obtenha em: Supabase Dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_ANON_KEY=your_supabase_anon_key

# Bucket e pasta onde os PDFs serão salvos
SUPABASE_STORAGE_BUCKET=lattes-cvs
SUPABASE_STORAGE_FOLDER=raw

# true: retorna URL pública (bucket público)
# false: retorna URL assinada com expiração
SUPABASE_STORAGE_PUBLIC=true
SUPABASE_SIGNED_URL_EXPIRES_IN=3600

# ===========================================
# GEMINI (para endpoint /summarize)
# ===========================================
# GEMINI_API_KEY=AIza...

# ===========================================
# OLLAMA (para endpoint /summarize)
# ===========================================
# Endpoint da API local do Ollama (modo OpenAI-compatible)
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Modelo default sugerido quando usar provedor ollama
OLLAMA_MODEL=llama3.1
# Opcional para cenários com autenticação
# OLLAMA_API_KEY=ollama
