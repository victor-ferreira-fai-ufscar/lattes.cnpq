# Lattes Scraper - Configurações de Ambiente
# Copie este arquivo para .env e configure suas chaves

# ===========================================
# API KEYS (OBRIGATÓRIAS)
# ===========================================

# OpenAI API Key
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# CONFIGURAÇÕES DO NAVEGADOR (OPCIONAIS)
# ===========================================

# Caminho para o executável do Chrome/Chromium
# Padrão: /opt/google/chrome-unstable/google-chrome-unstable
CHROME_PATH=/opt/google/chrome-unstable/google-chrome-unstable

# Porta do backend (padrão: 8000)
BACKEND_PORT=8000

# Porta do frontend (padrão: 3000)
FRONTEND_PORT=3000

# ===========================================
# CONFIGURAÇÕES AVANÇADAS (OPCIONAIS)
# ===========================================

# Timeout para requests da API (segundos)
API_TIMEOUT=30

# Diretório de saída para arquivos gerados
OUTPUT_DIR=output

# Configurações do Playwright
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true

# ===========================================
# SUPABASE (FUTURO)
# ===========================================

# Quando implementar Supabase
# SUPABASE_URL=your_supabase_url
# SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
