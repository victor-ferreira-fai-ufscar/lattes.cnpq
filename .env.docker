# ===========================================
# DOCKER COMPOSE - Valores Padrão para Desenvolvimento
# ===========================================
# Este arquivo contém valores padrão para `docker-compose up`
# Copie para `.env` e customize conforme necessário

# ===========================================
# PLAYWRIGHT - NAVEGADOR
# ===========================================
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=45000
SCRAPE_RETRY_COUNT=3

# ===========================================
# SERVIDOR
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ===========================================
# OUTPUT & STORAGE
# ===========================================
OUTPUT_DIR=output
OUTPUT_BUCKET=lattes-cvs
OUTPUT_FOLDER_RAW=raw
OUTPUT_FOLDER_STRUCTURED=structured
BATCH_MAX_CONCURRENT=5
BATCH_TIMEOUT_TOTAL_SECONDS=3600

# ===========================================
# LOGGING
# ===========================================
LOG_LEVEL=INFO

# ===========================================
# SUPABASE STORAGE
# ===========================================
# NOTA: Configure estas variáveis no seu `.env` real
# Incluídas aqui apenas como referência
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# SUPABASE_STORAGE_BUCKET=lattes-cvs
# SUPABASE_STORAGE_FOLDER=raw
# SUPABASE_STORAGE_PUBLIC=true

# ===========================================
# OPENAI (para endpoint /summarize)
# ===========================================
# NOTA: Configure no `.env` real se for usar resumos
# OPENAI_API_KEY=sk-...

# ===========================================
# FRONTEND
# ===========================================
NEXT_PUBLIC_API_URL=http://localhost:8000
