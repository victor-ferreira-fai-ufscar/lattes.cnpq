# ===========================================
# DOCKER COMPOSE - Valores Padrão para Desenvolvimento
# ===========================================
# Este arquivo define variáveis de runtime para os containers.
# Para alterar interpolação do docker-compose (ex.: portas), use variáveis
# de shell ou um arquivo `.env` na raiz do projeto.

# ===========================================
# PLAYWRIGHT - NAVEGADOR
# ===========================================
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true

# ===========================================
# SERVIDOR
# ===========================================
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ===========================================
# OLLAMA (opcional para endpoint /summarize)
# ===========================================
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Chaves e variáveis sensíveis do backend devem ficar em `backend/.env`.
